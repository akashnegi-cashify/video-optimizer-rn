# =============================================================================
# Cashify-OPS — Podfile (RN host + Flutter module add-to-app)
# Static frameworks: required because Flutter ships frameworks; RN's default
# dynamic linkage conflicts with that, so we force static everywhere.
# =============================================================================

# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, '16.0'
prepare_react_native_project!

# Force STATIC frameworks for Flutter add-to-app compatibility.
ENV['USE_FRAMEWORKS'] ||= 'static'

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

# Path to the Flutter module — relative to ios/Podfile (one level up from ios/).
flutter_application_path = '../flutter_module'
load File.join(flutter_application_path, '.ios', 'Flutter', 'podhelper.rb')

target 'CashifyOps' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  # Flutter pods (engine + all plugins from flutter_module/pubspec.yaml).
  install_all_flutter_pods(flutter_application_path)

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
    )
    flutter_post_install(installer) if defined?(flutter_post_install)

    # Force iOS 16.0 deployment target on every pod (some plugins still ship 13.0 default).
    installer.pods_project.targets.each do |t|
      t.build_configurations.each do |bc|
        bc.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '16.0'
      end
    end
  end
end
