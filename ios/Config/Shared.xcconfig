// =============================================================================
// Cashify-OPS — Shared xcconfig (deployment target, common build flags)
// Wire into the Xcode target via:
//   Project > Info > Configurations > Debug/Release base config = Config/<Flavor>.xcconfig
// Each per-flavor xcconfig #includes this file.
// =============================================================================

IPHONEOS_DEPLOYMENT_TARGET = 16.0
SWIFT_VERSION = 5.0
ENABLE_BITCODE = NO
ALWAYS_EMBED_SWIFT_STANDARD_LIBRARIES = YES

// Marketing version + build number — wired manually in Info.plist or via build script.
MARKETING_VERSION = 6.0.4
CURRENT_PROJECT_VERSION = 87
