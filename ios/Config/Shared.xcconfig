// =============================================================================
// Cashify-OPS — Shared xcconfig (deployment target, common build flags)
// Per-flavor values (PRODUCT_BUNDLE_IDENTIFIER, DISPLAY_NAME, MARKETING_VERSION,
// CURRENT_PROJECT_VERSION) come from env/.env.<flavor> via tmp.xcconfig — see the
// CashifyOps-{Debug,Release}.xcconfig wrappers.
// =============================================================================

IPHONEOS_DEPLOYMENT_TARGET = 16.0
SWIFT_VERSION = 5.0
ENABLE_BITCODE = NO
ALWAYS_EMBED_SWIFT_STANDARD_LIBRARIES = YES
