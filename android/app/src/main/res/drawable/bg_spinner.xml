<?xml version="1.0" encoding="utf-8"?>




<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:gravity="bottom|right">
        <shape xmlns:android="http://schemas.android.com/apk/res/android"
            android:shape="rectangle">
            <solid android:color="@android:color/white" />
            <stroke
                android:width="@dimen/space_1dp"
                android:color="#000000" />
            <corners android:radius="@dimen/space_4dp" />
        </shape>
    </item>

    <item  android:width="@dimen/space_50dp"


        android:gravity="center_vertical|right">

        <shape android:shape="rectangle">
            <corners
                android:bottomRightRadius="@dimen/space_4dp"
                android:topRightRadius="@dimen/space_4dp"/>
            <solid android:color="#dcdcdc"/>
            <stroke
                android:width="@dimen/space_1dp"
                android:color="#000000" />
        </shape>
    </item>



    <item
        android:right="@dimen/space_10dp"
        android:gravity="center_vertical|right|center_horizontal"
        android:width="@dimen/space_30dp"
        android:height="@dimen/space_30dp"
        android:drawable="@drawable/ic_arrow_drop_down"/>





</layer-list>






