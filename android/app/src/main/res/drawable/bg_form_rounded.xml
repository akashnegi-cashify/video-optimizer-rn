<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Background color -->
    <stroke
        android:width="1dp"
        android:color="@color/teal" />

    <!-- Padding -->
    <padding
        android:bottom="5dp"
        android:left="5dp"
        android:right="5dp"
        android:top="5dp" />

    <!-- Corner radius -->
    <corners android:radius="6dp" />

</shape>