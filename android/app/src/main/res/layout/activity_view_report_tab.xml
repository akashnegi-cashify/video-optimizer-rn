<?xml version="1.0" encoding="utf-8"?>
<layout>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".module.engineer.view_report.ui.activity.ViewReportTabActivity">
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/sliding_tabs"
        android:layout_marginStart="@dimen/space_8dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="@dimen/space_8dp"
        android:minHeight="@dimen/space_60dp"
        app:tabIndicatorColor="@color/teal"
        app:tabIndicatorHeight="@dimen/space_4dp"
        app:tabMode="scrollable"
        app:tabTextColor="@color/teal"/>

    <androidx.viewpager.widget.ViewPager
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/sliding_tabs"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="@dimen/space_4dp"
        android:layout_weight="1"/>
</androidx.constraintlayout.widget.ConstraintLayout>
</layout>