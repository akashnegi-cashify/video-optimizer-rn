<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cv_card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?android:attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?android:attr/selectableItemBackground"
    >
    <androidx.cardview.widget.CardView
        app:cardCornerRadius="@dimen/space_10dp"
        app:cardElevation="@dimen/space_5dp"
        android:layout_marginStart="@dimen/space_6dp"
        android:layout_marginTop="@dimen/space_6dp"
        android:layout_marginEnd="@dimen/space_6dp"
        android:layout_marginBottom="@dimen/space_6dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:id="@+id/cl_container"
            android:layout_height="wrap_content">

            <LinearLayout
                android:id="@+id/ll_detail"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_marginEnd="@dimen/space_16dp"
                android:orientation="vertical"
                android:paddingStart="@dimen/space_4dp"
                android:paddingEnd="@dimen/space_4dp"
                android:paddingBottom="@dimen/space_4dp"
                app:layout_constraintEnd_toStartOf="@+id/ll_counter"
                app:layout_constraintHorizontal_weight="1"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:id="@+id/tv_line_1"
                    style="@style/SemiBold.Black.TextSize14"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_9dp"
                    app:layout_constraintStart_toStartOf="parent" />

                <View
                    android:id="@+id/void_view"
                    android:layout_width="@dimen/space_21dp"
                    android:layout_height="@dimen/space_2dp"
                    android:layout_marginTop="@dimen/space_4dp"
                    android:background="@android:color/black" />

                <TextView
                    android:id="@+id/tv_line_2"
                    style="@style/Regular.Black.TextSize12"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_9dp" />

                <TextView
                    android:id="@+id/tv_line_3"
                    style="@style/Regular.Black.TextSize12"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_9dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/ll_counter"
                android:layout_width="0dp"
                android:layout_height="@dimen/space_35dp"
                android:layout_marginEnd="@dimen/space_8dp"
                android:orientation="horizontal"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <CheckBox
                    android:clickable="false"
                    android:id="@+id/cb_order_part"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

            </LinearLayout>


        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>



</FrameLayout>