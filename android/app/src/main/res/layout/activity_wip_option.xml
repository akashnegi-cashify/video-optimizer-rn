<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
                name="viewModel"
                type="in.cashify.androidtrc.module.engineer.data.WipOptionActivityModel" />
    </data>


    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

    <androidx.constraintlayout.widget.ConstraintLayout

            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

        <androidx.cardview.widget.CardView
                android:id="@+id/cv_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_6dp"
                android:layout_marginTop="@dimen/space_6dp"
                android:layout_marginEnd="@dimen/space_6dp"
                android:layout_marginBottom="@dimen/space_6dp"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground"
                app:cardCornerRadius="@dimen/space_10dp"
                app:cardElevation="@dimen/space_5dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                    android:id="@+id/rl_sell_old_device"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_marginEnd="@dimen/space_16dp"
                    android:orientation="vertical"
                    android:paddingStart="@dimen/space_4dp"
                    android:paddingEnd="@dimen/space_4dp">

                <TextView
                        android:id="@+id/tv_line_1"
                        style="@style/SemiBold.Black.TextSize14"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_9dp"
                        app:layout_constraintStart_toStartOf="parent" />

                <TextView
                        android:id="@+id/tv_line_2"
                        style="@style/Regular.Black.TextSize12"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_9dp" />

                <TextView

                        android:id="@+id/tv_line_3"
                        style="@style/Regular.Black.TextSize12"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                         />

                <TextView

                    android:id="@+id/tv_repair_type"
                    style="@style/Regular.Black.TextSize12"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    />

                <TextView

                    android:id="@+id/tv_grade"
                    style="@style/Regular.Black.TextSize12"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    />
                <TextView
                    android:id="@+id/tv_imei"
                    style="@style/Regular.Black.TextSize12"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/space_9dp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>






        <androidx.cardview.widget.CardView
            android:id="@+id/cv_card_device_issue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_6dp"
            android:layout_marginTop="@dimen/space_6dp"
            android:layout_marginEnd="@dimen/space_6dp"
            android:layout_marginBottom="@dimen/space_6dp"
            android:background="?android:attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            tools:visibility="visible"

            android:foreground="?android:attr/selectableItemBackground"
            app:cardCornerRadius="@dimen/space_10dp"
            app:cardElevation="@dimen/space_5dp"

            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/cv_card">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                >
                <TextView
                    android:id="@+id/tv_device_issues"
                    style="@style/SemiBold.Black.TextSize14"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_4dp"
                    android:text="@string/device_issues"
                    android:layout_marginStart="@dimen/space_4dp"
                    android:layout_marginEnd="@dimen/space_16dp"
                    android:layout_marginBottom="@dimen/space_4dp" />
                <androidx.recyclerview.widget.RecyclerView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    tools:listitem="@layout/row_eng_device_issue"
                    android:layout_marginStart="@dimen/space_4dp"
                    android:layout_marginEnd="@dimen/space_16dp"
                    android:id="@+id/recl_device_issue"/>


                <TextView
                    android:id="@+id/lbl_rms_remarks"
                    style="@style/SemiBold.Black.TextSize14"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_4dp"
                    android:text="@string/rms_remarks"
                    android:layout_marginStart="@dimen/space_4dp"
                    android:layout_marginEnd="@dimen/space_16dp"
                    android:layout_marginBottom="@dimen/space_4dp" />


                <TextView
                    android:id="@+id/tv_rms_remarks"
                    style="@style/SemiBold.Black.TextSize14"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_4dp"
                    android:text="@string/rms_remarks"
                    android:layout_marginStart="@dimen/space_4dp"
                    android:layout_marginEnd="@dimen/space_16dp"
                    android:layout_marginBottom="@dimen/space_4dp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/tv_reason_heading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/re_qc_fail_reason"
            android:visibility="gone"
            tools:visibility="visible"
            style="@style/JetBlack.TextSize18"
            android:layout_margin="@dimen/space_20dp"
            app:layout_constraintStart_toStartOf="parent"
             app:layout_constraintTop_toBottomOf="@id/cv_card_device_issue"/>

        <TextView
            android:id="@+id/tv_reason"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            tools:text="Re-QC Fail Reason"
            android:visibility="gone"
            tools:visibility="visible"
            style="@style/DarkGrey.TextSize14"
            android:layout_margin="@dimen/space_10dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@id/tv_reason_heading"
            app:layout_constraintTop_toBottomOf="@id/tv_reason_heading"/>





        <TextView
                android:id="@+id/tv_progress"
                style="@style/SemiBold.Black.TextSize16"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_9dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tv_reason" />

        <Button
                android:id="@+id/btn_start_work"
                style="@style/TealButtonRoundCorner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/space_9dp"
                android:paddingStart="@dimen/space_8dp"
                android:paddingEnd="@dimen/space_8dp"
                android:text="@string/start_work"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tv_progress" />

        <LinearLayout
                android:id="@+id/ll_btn_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_9dp"
                android:minWidth="@dimen/space_70dp"
                android:orientation="vertical"
                android:visibility="gone"
            tools:visibility="visible"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tv_progress">

            <Button
                    android:id="@+id/btn_put_hold"
                    style="@style/TealButtonRoundCorner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/space_9dp"
                    android:paddingStart="@dimen/space_8dp"
                    android:paddingEnd="@dimen/space_8dp"
                    android:text="@string/put_on_hold" />


            <Button
                    android:id="@+id/btn_mark_ok"
                    style="@style/TealButtonRoundCorner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/space_9dp"
                    android:paddingStart="@dimen/space_8dp"
                    android:paddingEnd="@dimen/space_8dp"
                    android:text="@string/mark_ok" />


            <Button
                    android:id="@+id/btn_order_part"
                    style="@style/TealButtonRoundCorner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/space_9dp"
                    android:paddingStart="@dimen/space_8dp"
                    android:paddingEnd="@dimen/space_8dp"
                    android:text="@string/order_part"
                tools:visibility="visible"
                    android:visibility="gone" />

            <Button
                    android:id="@+id/btn_view_parts"
                    style="@style/TealButtonRoundCorner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/space_9dp"
                    android:paddingStart="@dimen/space_8dp"
                    android:paddingEnd="@dimen/space_8dp"
                    android:text="@string/view_parts" />

            <Button
                    android:id="@+id/btn_mark_fi"
                    style="@style/TealButtonRoundCorner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/space_9dp"
                    android:paddingStart="@dimen/space_8dp"
                    android:paddingEnd="@dimen/space_8dp"
                    android:text="Mark FI" />


            <Button
                    android:id="@+id/btn_mark_ffi"
                    style="@style/TealButtonRoundCorner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/space_9dp"
                    android:paddingStart="@dimen/space_8dp"
                    android:paddingEnd="@dimen/space_8dp"
                    android:text="@string/mark_nff" />

            <Button
                    android:id="@+id/btn_mark_nr"
                    style="@style/TealButtonRoundCorner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/space_9dp"
                    android:paddingStart="@dimen/space_8dp"
                    android:paddingEnd="@dimen/space_8dp"
                    android:text="@string/mark_nr" />


            <Button
                android:id="@+id/btn_send_tl"
                style="@style/TealButtonRoundCorner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/space_9dp"
                android:paddingStart="@dimen/space_8dp"
                android:paddingEnd="@dimen/space_8dp"
                android:text="@string/send_to_tl" />


        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>
</layout>