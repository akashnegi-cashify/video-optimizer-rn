<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

        <import type="android.view.View" />

        <variable
            name="viewModel"
            type="in.cashify.androidtrc.module.inventory_manager.InventoryManagerPendingPartViewModel" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:tools="http://schemas.android.com/tools"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white"
        tools:context=".module.inventory_manager.fragment.pending.IMPendingDevicePartDetailsFragment">

        <ScrollView
            android:id="@+id/scroll"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintBottom_toTopOf="@+id/bottom_lay"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintTop_toTopOf="parent">

                <androidx.cardview.widget.CardView
                    android:id="@+id/card_details"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/space_10dp"
                    android:elevation="@dimen/cardview_default_elevation"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">


                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/space_5dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:padding="@dimen/space_5dp">

                            <TextView
                                style="@style/Medium.Teal.TextSize14"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/device_barcode" />

                            <TextView
                                android:id="@+id/tv_barcode"
                                style="@style/Medium.JetBlack.TextSize14"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/space_10dp"
                                android:layout_weight="1"
                                android:gravity="end"
                                tools:text="dfuyfjdifflyudfukl" />


                        </LinearLayout>


                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:padding="@dimen/space_5dp">

                            <TextView
                                style="@style/Medium.Teal.TextSize14"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/device_name" />

                            <TextView
                                android:id="@+id/tv_device_name"
                                style="@style/Medium.JetBlack.TextSize14"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/space_10dp"
                                android:layout_weight="1"
                                android:gravity="end"
                                tools:text="dfuyfjdifflyudfukl" />


                        </LinearLayout>


                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:padding="@dimen/space_5dp">

                            <TextView
                                style="@style/Medium.Teal.TextSize14"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/engineers_name" />

                            <TextView
                                android:id="@+id/tv_engineer_name"
                                style="@style/Medium.JetBlack.TextSize14"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/space_10dp"
                                android:layout_weight="1"
                                android:gravity="end"
                                tools:text="dfuyfjdifflyudfukl" />


                        </LinearLayout>


                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:padding="@dimen/space_5dp">

                            <TextView
                                style="@style/Medium.Teal.TextSize14"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/location" />

                            <TextView
                                android:id="@+id/tv_location"
                                style="@style/Medium.JetBlack.TextSize14"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/space_10dp"
                                android:layout_weight="1"
                                android:gravity="end"
                                tools:text="dfuyfjdifflyudfukl" />


                        </LinearLayout>


                    </LinearLayout>
                </androidx.cardview.widget.CardView>


                <TextView
                    android:id="@+id/btnSync"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:layout_margin="@dimen/space_10dp"
                    android:layout_marginTop="@dimen/space_10dp"
                    android:background="@color/teal"

                    android:drawableStart="@drawable/ic_sync"
                    android:drawablePadding="@dimen/space_5dp"
                    android:paddingStart="@dimen/space_10dp"
                    android:paddingTop="@dimen/space_5dp"
                    android:paddingEnd="@dimen/space_10dp"
                    android:paddingBottom="@dimen/space_5dp"
                    android:text="@string/sync"
                    android:textColor="@color/white"
                    app:layout_constraintEnd_toEndOf="parent"

                    app:layout_constraintTop_toBottomOf="@+id/card_details" />


                <androidx.cardview.widget.CardView
                    android:id="@+id/card_part_details"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/space_10dp"
                    android:layout_marginTop="@dimen/space_20dp"
                    app:layout_constraintBottom_toTopOf="@+id/bottom_lay"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/btnSync">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/space_10dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                style="@style/Medium.Teal.TextSize14"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/part_name" />


                            <TextView
                                android:id="@+id/tv_part_name"
                                style="@style/Medium.JetBlack.TextSize14"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/space_10dp"
                                android:layout_weight="1"
                                android:gravity="end"
                                tools:text="hgasJkaLzshgj" />
                        </LinearLayout>


                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_10dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                style="@style/Medium.Teal.TextSize14"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/part_sku" />


                            <TextView
                                android:id="@+id/tv_part_sku"
                                style="@style/Medium.JetBlack.TextSize14"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/space_10dp"
                                android:layout_weight="1"
                                android:gravity="end"
                                tools:text="hgasJkaLzshgj" />
                        </LinearLayout>


                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_10dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                style="@style/Medium.Teal.TextSize14"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/part_status" />


                            <TextView
                                android:id="@+id/tv_part_status"
                                style="@style/Medium.JetBlack.TextSize14"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/space_10dp"
                                android:layout_weight="1"
                                android:gravity="end"
                                tools:text="hgasJkaLzshgj" />
                        </LinearLayout>


                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_10dp"
                            android:gravity="center"
                            android:orientation="horizontal">

                            <TextView
                                style="@style/Medium.Teal.TextSize14"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/part_color" />


                            <TextView
                                android:id="@+id/tv_part_color"
                                style="@style/Medium.JetBlack.TextSize14"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/space_10dp"
                                android:layout_weight="1"
                                android:gravity="end"
                                tools:text="hgasJkaLzshgj" />
                        </LinearLayout>


                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <LinearLayout
                                android:id="@+id/ll_ap_sku"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/space_10dp"
                                android:orientation="horizontal">

                                <TextView
                                    style="@style/Medium.Teal.TextSize14"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="@string/alternate_part_sku" />


                                <TextView
                                    android:id="@+id/tv_alternate_part_sku"
                                    style="@style/Medium.JetBlack.TextSize14"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="@dimen/space_10dp"
                                    android:layout_weight="1"
                                    android:gravity="end"
                                    tools:text="hgasJkaLzshgj" />
                            </LinearLayout>


                            <LinearLayout
                                android:id="@+id/ll_ap_status"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/space_10dp"
                                android:orientation="horizontal">

                                <TextView
                                    style="@style/Medium.Teal.TextSize14"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="@string/alternate_part_status" />


                                <TextView
                                    android:id="@+id/tv_alternate_part_status"
                                    style="@style/Medium.JetBlack.TextSize14"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="@dimen/space_10dp"
                                    android:layout_weight="1"
                                    android:gravity="end"
                                    tools:text="hgasJkaLzshgj" />
                            </LinearLayout>


                            <LinearLayout
                                android:id="@+id/ap_pColor"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/space_10dp"
                                android:orientation="horizontal">

                                <TextView
                                    style="@style/Medium.Teal.TextSize14"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="@string/alternate_part_color" />


                                <TextView
                                    android:id="@+id/tv_alternate_part_color"
                                    style="@style/Medium.JetBlack.TextSize14"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="@dimen/space_10dp"
                                    android:layout_weight="1"
                                    android:gravity="end"
                                    tools:text="hgasJkaLzshgj" />
                            </LinearLayout>


                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/lay_available_quantity"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_10dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                style="@style/Medium.Teal.TextSize14"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/available_quantity" />


                            <TextView
                                android:id="@+id/tv_available_quantity"
                                style="@style/Medium.JetBlack.TextSize14"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"

                                android:layout_marginStart="@dimen/space_10dp"
                                android:layout_weight="1"
                                android:background="@color/teal"
                                android:gravity="center"
                                android:padding="@dimen/space_3dp"
                                android:text="@string/get_quantity"
                                android:textColor="@color/white" />


                            <TextView
                                android:id="@+id/tv_quantity"
                                style="@style/Medium.JetBlack.TextSize14"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"

                                android:layout_marginStart="@dimen/space_10dp"
                                android:layout_weight="1"
                                android:gravity="end"
                                android:padding="@dimen/space_3dp"
                                android:text="@string/get_quantity" />
                        </LinearLayout>


                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_10dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                style="@style/Medium.Teal.TextSize14"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/requested_quantity" />


                            <TextView
                                android:id="@+id/tv_requested_quantity"
                                style="@style/Medium.JetBlack.TextSize14"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/space_10dp"
                                android:layout_weight="1"
                                android:gravity="end"
                                tools:text="hgasJkaLzshgj" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/ll_suggested_barcode"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_10dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:visibility="gone">

                            <TextView
                                style="@style/Medium.Teal.TextSize14"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/suggested_barcode"
                                android:textColor="@color/confirm"
                                android:textSize="@dimen/space_14dp"
                                android:textStyle="bold" />


                            <TextView
                                android:id="@+id/tv_suggested_barcode"
                                style="@style/Medium.JetBlack.TextSize14"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/space_10dp"
                                android:layout_weight="1"
                                android:gravity="end"
                                tools:text="hgasJkaLzshgj" />
                        </LinearLayout>

                    </LinearLayout>


                </androidx.cardview.widget.CardView>


            </LinearLayout>

        </ScrollView>


        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/bottom_lay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent">


            <LinearLayout
                android:id="@+id/linear_btn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/space_10dp"
                android:orientation="horizontal"
                app:layout_constraintBottom_toBottomOf="parent">

                <LinearLayout
                    android:id="@+id/lay_btn"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="4"
                    android:orientation="horizontal">


                    <Button
                        android:id="@+id/btn_cancel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_margin="@dimen/space_10dp"
                        android:layout_weight="1"
                        android:background="@null"
                        android:text="@string/cancel"
                        android:textColor="@color/red"
                        android:textSize="@dimen/space_10dp"
                        app:layout_constraintEnd_toStartOf="@+id/btn_assign"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/card_part_details" />


                    <Button
                        android:id="@+id/btn_assign"
                        style="@style/TealButton.TextSize10"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_margin="@dimen/space_10dp"
                        android:layout_marginStart="@dimen/space_20dp"
                        android:layout_weight="1"
                        android:text="@string/assign"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@+id/btn_cancel"
                        app:layout_constraintTop_toBottomOf="@+id/card_part_details" />


                    <Button
                        android:id="@+id/btn_dead_part"
                        style="@style/TealButton.TextSize10"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_margin="@dimen/space_10dp"
                        android:layout_marginStart="@dimen/space_20dp"
                        android:layout_weight="1"
                        android:text="@string/dead_part"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@+id/btn_cancel"
                        app:layout_constraintTop_toBottomOf="@+id/card_part_details" />


                    <Button
                        android:id="@+id/btn_alternate_part"
                        style="@style/TealButton.TextSize10"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_vertical"
                        android:layout_margin="@dimen/space_10dp"
                        android:layout_marginStart="@dimen/space_20dp"
                        android:layout_weight="1"
                        android:text="@string/alternate_part"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@+id/btn_cancel"
                        app:layout_constraintTop_toBottomOf="@+id/card_part_details" />


                </LinearLayout>


                <Button
                    android:id="@+id/btn_go_back"
                    style="@style/TealButton.TextSize10"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/space_10dp"
                    android:layout_marginStart="@dimen/space_20dp"
                    android:layout_weight="1"
                    android:text="@string/go_back"

                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/btn_cancel"
                    app:layout_constraintTop_toBottomOf="@+id/card_part_details" />


            </LinearLayout>


        </androidx.constraintlayout.widget.ConstraintLayout>


    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>