<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    android:padding="@dimen/space_10dp"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/click_on_confirm_tl"
        android:id="@+id/lbl_send_to_tl"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        style="@style/Teal.TextSize16"
        app:layout_constraintEnd_toEndOf="parent"/>



 <LinearLayout
     android:layout_width="match_parent"
     android:layout_height="wrap_content"
     app:layout_constraintStart_toStartOf="parent"
     app:layout_constraintTop_toBottomOf="@+id/lbl_send_to_tl"
     android:id="@+id/lay_device_name"
     android:layout_marginTop="@dimen/space_10dp"
     app:layout_constraintEnd_toEndOf="parent">
     <TextView
         android:layout_width="0dp"
         android:layout_height="wrap_content"
         android:layout_weight="1"
         style="@style/Medium.JetBlack.TextSize16"
         android:text="@string/device_name"
         android:textColor="@color/darkGrey"
         android:layout_marginEnd="@dimen/space_10dp"
         android:id="@+id/lbl_device_name"/>

     <TextView
         android:layout_width="0dp"
         android:layout_height="wrap_content"
         android:layout_weight="1"
         android:textColor="@color/darkGrey"
         style="@style/Medium.JetBlack.TextSize16"
         tools:text="hgefjkjmvjgkfkjd"
         android:id="@+id/tv_device_name"/>
 </LinearLayout>





    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="@dimen/space_10dp"
        app:layout_constraintTop_toBottomOf="@+id/lay_device_name"
        android:id="@+id/lay_barcode"
        app:layout_constraintEnd_toEndOf="parent">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="@dimen/space_10dp"
            style="@style/Medium.JetBlack.TextSize16"
            android:text="@string/barcode"
            android:textColor="@color/darkGrey"
            android:id="@+id/lbl_barcode"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            style="@style/Medium.JetBlack.TextSize16"
            tools:text="hgefjkjmvjgkfkjd"
            android:textColor="@color/darkGrey"
            android:id="@+id/tv_barcode"/>
    </LinearLayout>




    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_10dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/lay_barcode"
        android:id="@+id/lay_color"
        app:layout_constraintEnd_toEndOf="parent">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            style="@style/Medium.JetBlack.TextSize16"
            android:text="@string/color"
            android:textColor="@color/darkGrey"
            android:layout_marginEnd="@dimen/space_10dp"
            android:id="@+id/lbl_color"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/darkGrey"
            style="@style/Medium.JetBlack.TextSize16"
            tools:text="hgefjkjmvjgkfkjd"
            android:id="@+id/tv_color"/>
    </LinearLayout>




    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="@dimen/space_10dp"
        app:layout_constraintTop_toBottomOf="@+id/lay_color"
        android:id="@+id/lay_time"
        app:layout_constraintEnd_toEndOf="parent">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            style="@style/Medium.JetBlack.TextSize16"
            android:text="@string/imei"
            android:textColor="@color/darkGrey"
            android:layout_marginEnd="@dimen/space_10dp"
            android:id="@+id/lbl_imei"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/darkGrey"
            style="@style/Medium.JetBlack.TextSize16"
            tools:text="hgefjkjmvjgkfkjd"
            android:id="@+id/tv_imei"/>
    </LinearLayout>

<ImageView
    android:layout_width="@dimen/space_10dp"
    android:layout_height="@dimen/space_10dp"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintTop_toBottomOf="@+id/lay_time"
   android:src="@drawable/ic_star"
    android:layout_marginTop="@dimen/space_10dp"
android:textColor="@color/red"
    android:textSize="@dimen/text_size_20sp"


    android:gravity="bottom"
    android:id="@+id/lbl_mandatory_star"/>

    <Spinner
        android:layout_width="0dp"
        android:layout_height="wrap_content" android:background="@drawable/bg_spinner"
        android:id="@+id/spinner_reason"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginEnd="@dimen/space_5dp"
        app:layout_constraintEnd_toStartOf="@+id/lbl_mandatory_star"

        app:layout_constraintTop_toBottomOf="@+id/lbl_mandatory_star"/>



    <TextView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/select_reasons_from_above_list"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="@dimen/padding_10"
        style="@style/Red.TextSize12"
        android:id="@+id/lbl_reason"

        app:layout_constraintTop_toBottomOf="@+id/spinner_reason"
        app:layout_constraintEnd_toEndOf="parent"/>



    <View
        android:layout_width="match_parent"
        android:layout_height="@dimen/space_2dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/lbl_reason"
        android:background="@color/black"
        android:id="@+id/view"
        android:layout_marginTop="@dimen/space_10dp"
       />



    <Button
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:id="@+id/btn_cancel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/view"
        android:background="@null"
        android:layout_marginEnd="@dimen/space_20dp"
        app:layout_constraintEnd_toStartOf="@+id/btn_confirm"
        android:layout_marginTop="@dimen/space_20dp"
        android:text="@string/cancel"
        style="@style/Red.TextSize20"/>


    <Button
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:id="@+id/btn_confirm"
        app:layout_constraintStart_toEndOf="@+id/btn_cancel"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/view"
        android:layout_marginTop="@dimen/space_20dp"
        android:text="@string/confirm"
        style="@style/TealButtonRoundCorner"/>

</androidx.constraintlayout.widget.ConstraintLayout>