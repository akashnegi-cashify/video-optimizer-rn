<?xml version="1.0" encoding="utf-8"?>

<layout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
    <data>

    </data>
    <androidx.constraintlayout.widget.ConstraintLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

        <TextView android:layout_width="match_parent"
                  android:id="@+id/tvTrayBarCode"
                  style="@style/SemiBold.Black.TextSize14"
                  android:text="Tray Barcode -GUR123"
                  android:layout_marginTop="@dimen/space_8dp"
                  app:layout_constraintTop_toTopOf="parent"
                  android:gravity="center"
                  app:layout_constraintStart_toStartOf="parent"
                  android:layout_height="wrap_content"/>

        <TextView android:layout_width="match_parent"
                  android:id="@+id/tvDeviceCount"
                  style="@style/Medium.JetBlack.TextSize12"
                  android:layout_marginTop="@dimen/space_16dp"
                  android:text="Count Of Devices -14"
                  app:layout_constraintTop_toBottomOf="@+id/tvTrayBarCode"
                  android:gravity="center"
                  app:layout_constraintStart_toStartOf="parent"
                  android:layout_height="wrap_content"/>

        <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cl_container"
                android:layout_width="match_parent"
                android:layout_height="@dimen/space_300dp"
                android:layout_marginStart="@dimen/space_6dp"
                android:padding="@dimen/space_1dp"
                android:layout_marginTop="@dimen/space_20dp"
                app:layout_constraintTop_toBottomOf="@id/tvDeviceCount"
                app:layout_constraintStart_toStartOf="parent"
                android:background="@drawable/bg_round_corner_black__dotted_outline"
                android:layout_marginEnd="@dimen/space_6dp"
                android:layout_marginBottom="@dimen/space_6dp">

            <FrameLayout android:layout_width="match_parent"
                         android:id="@+id/fm_container"
                         app:layout_constraintTop_toTopOf="parent"
                         app:layout_constraintStart_toStartOf="parent"
                         android:layout_height="match_parent"/>

            <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:id="@+id/blur_view"
                    android:background="#59C8B7"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    android:visibility="gone"
                    android:layout_height="match_parent">


                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                          style="@style/Regular.White.TextSize20"
                          app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"
                          app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"
                          android:text="Scanning is Disabled"/>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!--<com.google.android.material.switchmaterial.SwitchMaterial-->
        <!--android:id="@+id/toggleButton"-->
        <!--android:layout_width="wrap_content"-->
        <!--android:layout_marginTop="@dimen/space_20dp"-->
        <!--android:text="Click to disable scan"-->
        <!--app:layout_constraintStart_toStartOf="parent"-->
        <!--app:layout_constraintEnd_toEndOf="parent"-->
        <!--style="@style/Medium.JetBlack.TextSize14"-->
        <!--android:layoutDirection="rtl"-->
        <!--app:switchPadding="@dimen/space_8dp"-->
        <!--app:layout_constraintTop_toBottomOf="@id/cl_container"-->
        <!--android:checked="true"-->
        <!--android:layout_height="wrap_content"/>-->

        <LinearLayout android:layout_width="wrap_content"
                      android:orientation="horizontal"
                      android:layout_marginTop="@dimen/space_20dp"
                      app:layout_constraintStart_toStartOf="parent"
                      android:gravity="center_vertical"
                      app:layout_constraintEnd_toEndOf="parent"
                      app:layout_constraintTop_toBottomOf="@id/cl_container"
                      android:layout_height="wrap_content">

            <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/toggleButton"
                    android:layout_width="wrap_content"
                    android:checked="true"
                    android:layout_height="wrap_content"/>

            <TextView android:layout_width="match_parent"
                      android:id="@+id/tvSwitchText"
                      style="@style/Medium.JetBlack.TextSize14"
                      android:text="Click to disable scan"
                      android:layout_marginStart="@dimen/space_8dp"
                      app:layout_constraintTop_toBottomOf="@+id/tvTrayBarCode"
                      android:gravity="center_vertical"
                      app:layout_constraintStart_toStartOf="parent"
                      android:layout_height="wrap_content"/>

        </LinearLayout>


    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>