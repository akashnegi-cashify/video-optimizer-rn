                android:layout_height="wrap_content"

                android:text="@string/part_name"
                app:layout_constraintTop_toTopOf="@+id/tv_part_name"
                app:layout_constraintBottom_toBottomOf="@+id/tv_part_name"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/tv_part_name"/>


        <TextView
            android:id="@+id/tv_part_name"
            style="@style/Medium.JetBlack.TextSize14"
