<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

    </data>

    <androidx.cardview.widget.CardView
        android:id="@+id/cv_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/space_4dp"
        android:layout_marginTop="@dimen/space_4dp"
        android:layout_marginEnd="@dimen/space_4dp"
        android:layout_marginBottom="@dimen/space_4dp"
        android:background="?android:attr/selectableItemBackground"
        android:clickable="true"
          android:focusable="true"
        android:foreground="?android:attr/selectableItemBackground"
        app:cardCornerRadius="@dimen/space_4dp"
        app:cardElevation="@dimen/space_5dp">


        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="@dimen/space_4dp"
            android:layout_gravity="center"
            android:orientation="horizontal">


            <ImageView
                android:id="@+id/btn_remove"

                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="0.4"
                android:drawSelectorOnTop="true"

                android:text="Remove"
                android:src="@drawable/ic_cancel_red"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />



            <TextView
                android:id="@+id/tv_counter"
                style="@style/SemiBold.Black.TextSize14"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1."
                android:layout_marginStart="@dimen/space_10dp"
                 app:layout_constraintStart_toEndOf="@+id/btn_remove"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tv_part_name"
                style="@style/Medium.JetBlack.TextSize14"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Part 1"
                 app:layout_constraintStart_toEndOf="@+id/tv_counter"
                app:layout_constraintTop_toTopOf="@+id/tv_counter" />


            <TextView
                android:id="@+id/tv_part_count"
                style="@style/Medium.JetBlack.TextSize14"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_4dp"
                android:text="Part 1"
                android:layout_marginEnd="@dimen/space_10dp"
                app:layout_constraintEnd_toStartOf="@+id/camera"
                 app:layout_constraintStart_toEndOf="@+id/tv_part_name"
                app:layout_constraintTop_toTopOf="@+id/tv_counter" />

            <TextView
                android:id="@+id/tv_part_sku_text"
                style="@style/SemiBold.Black.TextSize14"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="sku"
                 app:layout_constraintStart_toStartOf="@+id/tv_part_name"
                app:layout_constraintTop_toBottomOf="@id/tv_counter"
                app:layout_constraintBottom_toTopOf="@id/tv_part_color"/>

            <TextView
                android:id="@+id/tv_part_sku"
                style="@style/Medium.JetBlack.TextSize14"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_4dp"
                android:text="Blue"
                android:layout_marginEnd="@dimen/space_10dp"
                app:layout_constraintEnd_toStartOf="@+id/camera"
                app:layout_constraintStart_toEndOf="@+id/tv_part_sku_text"
                app:layout_constraintTop_toTopOf="@+id/tv_part_sku_text" />

            <TextView
                android:id="@+id/tv_part_color_text"
                style="@style/SemiBold.Black.TextSize14"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="color"

                 app:layout_constraintStart_toStartOf="@+id/tv_part_name"
               app:layout_constraintBottom_toBottomOf="parent"
         />

            <TextView
                android:id="@+id/tv_part_color"
                style="@style/Medium.JetBlack.TextSize14"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_4dp"
                android:text="Blue"
                android:layout_marginEnd="@dimen/space_10dp"
                app:layout_constraintEnd_toStartOf="@+id/camera"
                 app:layout_constraintStart_toEndOf="@+id/tv_part_color_text"
                 app:layout_constraintTop_toTopOf="@+id/tv_part_color_text" />




            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_camera_teal"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:id="@+id/camera"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.cardview.widget.CardView>
</layout>