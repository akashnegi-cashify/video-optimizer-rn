<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto">
    <data>
        <variable name="storeOutViewModel"
            type="in.cashify.androidtrc.module.storageManager.data.StoreOutViewMadel" />

     </data>
    <LinearLayout
            android:orientation="vertical"
            android:background="@color/lightGrey"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
        >

        <LinearLayout
            android:id="@+id/ll_et_container"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="0.2"
            android:layout_marginTop="@dimen/space_22dp"
            android:layout_marginBottom="@dimen/space_30dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
             app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_remark"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/space_10dp"
                android:layout_marginRight="@dimen/space_10dp"
                android:layout_weight="1">

                <androidx.appcompat.widget.AppCompatEditText
                    android:id="@+id/et_barcode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Enter Barcode Manually" />

            </com.google.android.material.textfield.TextInputLayout>

            <Button
                android:id="@+id/btn_submit_barcode"
                style="@style/TealButtonRoundCorner"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Submit" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/rl_device"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="0.5"
            android:orientation="vertical"
            android:layout_gravity="center_vertical"
            android:layout_marginTop="@dimen/space_20dp"
            android:layout_margin="@dimen/space_20dp"
            android:paddingStart="@dimen/space_5dp"
            android:paddingEnd="@dimen/space_5dp"
              >

            <TextView
                android:id="@+id/device_name"
                style="@style/SemiBold.Black.TextSize14"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_20dp"
                />


            <TextView
                android:id="@+id/device_barcode"
                style="@style/SemiBold.Black.TextSize14"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_10dp"
                android:layout_marginBottom="@dimen/space_4dp"
               />

            <TextView
                android:id="@+id/location_barcode"
                style="@style/SemiBold.Black.TextSize14"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_10dp"
                android:layout_marginBottom="@dimen/space_20dp"
                />


        </LinearLayout>

        <LinearLayout
            android:id="@+id/buttonPanel"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:gravity="center_horizontal"
            android:layout_weight="0.4">

        <Button
            android:id="@+id/next_button"
            android:background="@drawable/disabled_next_button"
            android:layout_width="wrap_content"
            android:enabled="false"
            android:layout_height="wrap_content"
             android:text="Next" />
        </LinearLayout>



    </LinearLayout>
</layout>