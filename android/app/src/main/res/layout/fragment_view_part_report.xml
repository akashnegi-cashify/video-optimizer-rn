<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="@dimen/space_10dp"
            tools:context=".module.engineer.view_report.ui.fragment.ViewReportFragment">

            <in.cashify.androidtrc.util.widget.DateSpinner
                android:layout_width="match_parent"
                android:layout_height="@dimen/space_50dp"
                android:background="@drawable/bg_spinner"
                android:id="@+id/spinner_time"/>


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_20dp"
                android:id="@+id/lay_time"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="@dimen/space_20dp"
                    android:background="@drawable/black_strock_rect"
                    android:id="@+id/lay_start"
                    android:layout_height="wrap_content">

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/start_date"
                        android:paddingTop="@dimen/space_4dp"


                        android:layout_weight="1">
                        <com.google.android.material.textfield.TextInputEditText
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:id="@+id/et_start"
                            android:enabled="false"

                            android:paddingStart="@dimen/space_5dp"
                            android:paddingTop="@dimen/space_5dp"
                            android:paddingBottom="@dimen/space_5dp"
                            android:background="@null"
                            tools:text="1/2/10"/>
                    </com.google.android.material.textfield.TextInputLayout>


                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        app:ari_ratio="1"
                        android:background="@color/lightGrey"
                        android:layout_margin="@dimen/space_3dp"
                        android:paddingStart="@dimen/space_3dp"
                        android:paddingEnd="@dimen/space_3dp"
                        android:src="@drawable/ic_calendar"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="@dimen/space_20dp"
                    android:id="@+id/lay_end"
                    android:background="@drawable/black_strock_rect"
                    android:layout_height="wrap_content">

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/end_date"
                        android:paddingTop="@dimen/space_4dp"


                        android:layout_weight="1">
                        <com.google.android.material.textfield.TextInputEditText
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:id="@+id/et_end"
                            android:enabled="false"
                            android:paddingStart="@dimen/space_5dp"
                            android:paddingTop="@dimen/space_5dp"
                            android:paddingBottom="@dimen/space_5dp"
                            android:background="@null"
                            tools:text="1/2/10"/>
                    </com.google.android.material.textfield.TextInputLayout>


                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        app:ari_ratio="1"
                        android:background="@color/lightGrey"
                        android:layout_margin="@dimen/space_3dp"
                        android:paddingStart="@dimen/space_3dp"
                        android:paddingEnd="@dimen/space_3dp"
                        android:src="@drawable/ic_calendar"/>
                </LinearLayout>
            </LinearLayout>


            <CalendarView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/calendar"
                android:layout_marginTop="@dimen/space_10dp"/>


            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_20dp"
                android:id="@+id/card_efficiency">
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_margin="@dimen/space_10dp"
                    android:layout_height="wrap_content">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/avg_part_cost"
                        style="@style/Teal.TextSize14"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        android:id="@+id/lbl_avg_part_cost"/>




                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:id="@+id/tv_part_cost"
                        tools:text="12%"
                        style="@style/SemiBold.JetBlack.TextSize14"
                        android:layout_marginStart="@dimen/space_30dp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toEndOf="@+id/lbl_avg_part_cost"
                        app:layout_constraintEnd_toEndOf="parent"/>


                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/avg_part_consumption"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_marginTop="@dimen/space_20dp"
                        style="@style/Teal.TextSize14"
                        app:layout_constraintTop_toBottomOf="@+id/lbl_avg_part_cost"
                        android:id="@+id/lbl_avg_part_consumption"/>


                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        tools:text="4 hours 23 min"
                        app:layout_constraintStart_toEndOf="@+id/lbl_avg_part_consumption"
                        android:layout_marginTop="@dimen/space_20dp"
                        android:layout_marginStart="@dimen/space_30dp"
                        app:layout_constraintEnd_toEndOf="parent"
                        style="@style/SemiBold.JetBlack.TextSize14"
                        app:layout_constraintTop_toBottomOf="@+id/lbl_avg_part_cost"
                        android:id="@+id/tv_part_consumptn"/>
                </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.cardview.widget.CardView>


            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_30dp">
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <in.cashify.androidtrc.util.widget.pie_chart.PieChartView
                        android:id="@+id/pieChart"
                        android:layout_width="@dimen/space_200dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        android:layout_marginTop="@dimen/space_20dp"
                        android:layout_height="@dimen/space_200dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:id="@+id/pie_desc"
                        app:layout_constraintTop_toBottomOf="@+id/pieChart"
                        android:layout_marginTop="@dimen/space_20dp"
                        app:layout_constraintStart_toStartOf="parent"
                        android:orientation="vertical"
                        android:paddingBottom="@dimen/space_10dp"
                        app:layout_constraintEnd_toEndOf="parent">

                    </LinearLayout>


                </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.cardview.widget.CardView>



            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/space_20dp"
                android:layout_marginTop="@dimen/space_20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_margin="@dimen/space_10dp"
                    android:orientation="vertical"
                    android:paddingBottom="@dimen/space_10dp"
                    android:layout_height="wrap_content">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        android:id="@+id/lbl_leading_engineers"
                        style="@style/SemiBold.Teal.TextSize20"
                        android:text="@string/leading_engineers"/>


                    <View
                        android:layout_width="0dp"
                        android:layout_height="@dimen/space_3dp"
                        android:background="@color/lightGrey"
                        app:layout_constraintTop_toBottomOf="@+id/lbl_leading_engineers"
                        app:layout_constraintStart_toStartOf="parent"
                        android:id="@+id/view"
                        android:layout_marginTop="@dimen/space_10dp"
                        app:layout_constraintEnd_toEndOf="parent"/>



                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="horizontal">


                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="@string/avg_part_cost"
                            android:layout_weight="1"
                            style="@style/Teal.TextSize14"
                            android:layout_marginStart="@dimen/space_10dp"/>


                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            tools:text="Aghfdj"
                            android:layout_weight="1"
                            android:gravity="end"
                            android:layout_marginStart="@dimen/space_10dp"
                            android:background="@null"
                            android:id="@+id/et_avg_part_cost_name"
                            />



                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            tools:text="90 min"
                            android:gravity="end"
                            android:background="@null"
                            android:layout_weight="1"

                            android:layout_marginStart="@dimen/space_10dp"
                            android:id="@+id/et_avg_part_cost_value"
                            />

                    </LinearLayout>








                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:layout_marginTop="@dimen/space_10dp"
                        android:layout_marginBottom="@dimen/space_10dp"
                        android:orientation="horizontal">


                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="@string/avg_part_consumption"
                            android:layout_weight="1"
                            style="@style/Teal.TextSize14"
                            android:layout_marginStart="@dimen/space_10dp"/>


                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            tools:text="Aghfdj"
                            android:layout_weight="1"
                            android:gravity="end"
                            android:layout_marginStart="@dimen/space_10dp"
                            android:background="@null"
                            android:id="@+id/avg_part_consumptn_name"
                            />



                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            tools:text="90 min"
                            android:gravity="end"
                            android:layout_weight="1"
                            android:background="@null"
                            android:layout_marginStart="@dimen/space_10dp"
                            android:id="@+id/et_avg_part_consumptn_value"
                            />





                    </LinearLayout>














                </LinearLayout>


            </androidx.cardview.widget.CardView>


        </LinearLayout>
    </ScrollView>


        <ProgressBar
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:id="@+id/progressbar"/>
    </RelativeLayout>
</layout>