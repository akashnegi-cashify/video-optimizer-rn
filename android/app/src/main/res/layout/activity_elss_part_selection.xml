<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:bind="http://schemas.android.com/tools">

    <data>

        <variable
            name="viewModel"
            type="in.cashify.androidtrc.module.elss.data.ElssViewModel" />
    </data>

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">


    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:layout_marginBottom="@dimen/space_100dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:layout_marginBottom="@dimen/space_60dp">

            <androidx.cardview.widget.CardView
                android:id="@+id/cv_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_6dp"
                android:layout_marginTop="@dimen/space_6dp"
                android:layout_marginEnd="@dimen/space_6dp"
                android:layout_marginBottom="@dimen/space_6dp"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground"
                app:cardCornerRadius="@dimen/space_10dp"
                app:cardElevation="@dimen/space_5dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <LinearLayout
                    android:id="@+id/rl_device"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/space_16dp"
                    android:orientation="vertical"
                    android:paddingStart="@dimen/space_5dp"
                    android:paddingEnd="@dimen/space_5dp">

                    <TextView
                        android:id="@+id/tv_line_1"
                        style="@style/SemiBold.Black.TextSize14"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        tools:text="Device name"
                        android:layout_marginTop="@dimen/space_11dp" />


                    <TextView
                        android:id="@+id/tv_line_2"
                        style="@style/SemiBold.Black.TextSize14"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_4dp"
                        tools:text="Repair type"
                        android:layout_marginBottom="@dimen/space_4dp" />

                    <TextView
                        android:id="@+id/tv_line_3"
                        style="@style/SemiBold.Black.TextSize14"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_4dp"
                        tools:text="Device barcode"
                        android:layout_marginBottom="@dimen/space_4dp" />

                    <TextView
                        android:id="@+id/tv_line_4"
                        style="@style/SemiBold.Black.TextSize14"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_4dp"
                        tools:text="Device color"
                        android:layout_marginBottom="@dimen/space_4dp" />



                    <TextView
                        android:id="@+id/tv_device_issues"
                        style="@style/SemiBold.Black.TextSize14"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_4dp"
                      android:text="@string/device_issues"
                        android:layout_marginBottom="@dimen/space_4dp" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        tools:listitem="@layout/row_device_issue"
                        android:id="@+id/recl_device_issue"/>


                    <TextView
                        android:id="@+id/lbl_rms_remarks"
                        style="@style/SemiBold.Black.TextSize14"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_4dp"
                       android:text="@string/rms_remarks"
                        android:layout_marginBottom="@dimen/space_4dp" />

                    <TextView
                        android:id="@+id/tv_rms_remarks"
                        style="@style/SemiBold.Black.TextSize14"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"

                        tools:text="gfhdjksldhjkls;"
                        android:layout_marginBottom="@dimen/space_10dp" />

                    <TextView
                        android:id="@+id/tv_imei"
                        style="@style/SemiBold.Black.TextSize14"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        tools:text="imei"
                        android:layout_marginBottom="@dimen/space_10dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:id="@+id/ll_search"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/space_10dp"
                android:background="@drawable/bg_form_rounded"
                app:layout_constraintEnd_toEndOf="parent"
                android:gravity="center"
                android:padding="@dimen/space_7dp"
                android:layout_below="@+id/cv_card"
                app:layout_constraintTop_toBottomOf="@id/cv_card"
                android:orientation="horizontal"
                >
                <EditText
                    android:id="@+id/et_search_view"
                    android:layout_width="0dp"
                    android:layout_weight="0.8"
                    android:layout_height="wrap_content"
                     android:hint="Search Here"
                    android:background="@color/textView_bg_color"
                    android:imeOptions="actionDone" />

                <ImageView android:id="@+id/iv_clear"
                    android:layout_width="0dp"
                    android:layout_weight="0.1"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_cross_teal"


                    />

            </LinearLayout>



            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_parts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_10dp"
                android:layout_marginBottom="@dimen/space_8dp"
                android:padding="@dimen/space_4dp"
                tools:listitem="@layout/item_elss_manual_part"
                app:layout_constraintBottom_toTopOf="@+id/add_part_container"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_above="@+id/add_part_container"
                android:layout_below="@+id/ll_search"
                app:layout_constraintTop_toBottomOf="@+id/ll_search" />



        </LinearLayout>

    </androidx.core.widget.NestedScrollView>


        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/add_part_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_centerHorizontal="true"
            android:layout_marginBottom="@dimen/space_60dp"
            android:layout_gravity="center|bottom"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <ImageView
                android:id="@+id/iv_plus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@android:drawable/ic_input_add"
                app:tint="@color/black"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                style="@style/SemiBold.Black.TextSize20"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Add Parts"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintLeft_toRightOf="@+id/iv_plus"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>


                <include
                    android:clickable="true"
                    android:id="@+id/bottomView"
            layout="@layout/bottom_sheet_activity_elss_part_selection"
            bind:viewModel="@{viewModel}" />


    </androidx.coordinatorlayout.widget.CoordinatorLayout>


</layout>