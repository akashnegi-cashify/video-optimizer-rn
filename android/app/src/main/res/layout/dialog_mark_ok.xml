<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
 android:padding="@dimen/space_10dp"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        style="@style/SemiBold.Teal.TextSize18"
        android:id="@+id/lbl_mark_ok"
        android:text="@string/click_on_confirm_mark_ok"/>

    <TextView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/lbl_mark_ok"
        android:maxLines="1"
        app:layout_constraintEnd_toStartOf="@+id/tv_device_name"
        android:id="@+id/lbl_device_name"
        android:text="@string/device_name"
        style="@style/DarkGrey.TextSize18"
        android:fontFamily="@font/montserrat_semi_bold"
        android:layout_marginTop="@dimen/space_20dp"/>

    <TextView
        android:layout_width="0dp"
        android:layout_height="wrap_content"

        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/lbl_mark_ok"

        android:layout_marginStart="@dimen/space_10dp"
        app:layout_constraintStart_toEndOf="@+id/lbl_device_name"
        android:id="@+id/tv_device_name"
        tools:text="bhvjfdkslszhgdjkjfklkgyfuhidlkjiulfdfhdlouidofjiofjioldfjhufhdjilididfo"
        style="@style/DarkGrey.TextSize18"
        android:fontFamily="@font/montserrat_semi_bold"
        android:ellipsize="end"
        android:layout_marginTop="@dimen/space_20dp"/>








    <TextView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_device_name"
        android:maxLines="1"
        app:layout_constraintEnd_toStartOf="@+id/tv_barcode"
        android:id="@+id/lbl_barcode"
        android:text="@string/barcode"
        style="@style/DarkGrey.TextSize18"
        android:fontFamily="@font/montserrat_semi_bold"
        android:layout_marginTop="@dimen/space_10dp"/>

    <TextView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/lbl_barcode"

        android:layout_marginStart="@dimen/space_10dp"
        app:layout_constraintStart_toEndOf="@+id/lbl_device_name"
        android:id="@+id/tv_barcode"
        tools:text="bhvjfdkslszufydisosxhuiflujfncuxdhfycgfbhuyfuygfygcuy"
        style="@style/DarkGrey.TextSize18"
        android:fontFamily="@font/montserrat_semi_bold"
       />





    <TextView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_barcode"
        android:maxLines="1"
        app:layout_constraintEnd_toStartOf="@+id/tv_color"
        android:id="@+id/lbl_color"
        android:text="@string/color"
        style="@style/DarkGrey.TextSize18"
        android:fontFamily="@font/montserrat_semi_bold"
        android:layout_marginTop="@dimen/space_10dp"/>

    <TextView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/lbl_color"

        android:layout_marginStart="@dimen/space_10dp"
        app:layout_constraintStart_toEndOf="@+id/lbl_color"
        android:id="@+id/tv_color"
        tools:text="bhvjfdkslszhfgyduykdijnudhc6buyejoikijiudfhdcjosuxfyi"
        style="@style/DarkGrey.TextSize18"
        android:fontFamily="@font/montserrat_semi_bold"
      />





    <TextView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_color"
        android:maxLines="1"
        app:layout_constraintEnd_toStartOf="@+id/tv_imei"
        android:id="@+id/lbl_imei"
        android:text="@string/imei"
        style="@style/DarkGrey.TextSize18"
        android:fontFamily="@font/montserrat_semi_bold"
        android:layout_marginTop="@dimen/space_10dp"/>

    <TextView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/lbl_imei"

        android:layout_marginStart="@dimen/space_10dp"
        app:layout_constraintStart_toEndOf="@+id/lbl_imei"
        android:id="@+id/tv_imei"
        tools:text="bhvjfdkslyusdbfhcyjbfyjkjshbgfbcuihfnbduskfchdksz"
        style="@style/DarkGrey.TextSize18"
        android:fontFamily="@font/montserrat_semi_bold"
       />





    <View
        android:layout_width="match_parent"
        android:layout_height="@dimen/space_1dp"
        android:background="@color/darkGrey"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_imei"
        android:id="@+id/divider"
        android:layout_marginTop="@dimen/space_20dp"/>





    <Button
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/cancel"
        android:textColor="@color/red"
        android:textSize="@dimen/common_uploader_text_size_18sp"
        android:background="@null"
        app:layout_constraintStart_toStartOf="parent"
        android:id="@+id/cancel"
        app:layout_constraintEnd_toStartOf="@+id/confirm"
        android:layout_marginTop="@dimen/space_10dp"
        app:layout_constraintTop_toBottomOf="@+id/divider"/>

    <Button
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/confirm"
       style="@style/TealButtonRoundCorner"

        app:layout_constraintStart_toEndOf="@+id/cancel"
        app:layout_constraintEnd_toEndOf="parent"
        android:id="@+id/confirm"
        android:layout_marginTop="@dimen/space_10dp"
        app:layout_constraintTop_toBottomOf="@+id/divider"/>



</androidx.constraintlayout.widget.ConstraintLayout>