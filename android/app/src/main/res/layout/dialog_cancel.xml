<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="@dimen/space_10dp">

    <ImageView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/ic_cancel_red"
        android:layout_alignParentEnd="true"
        android:id="@+id/cancel"
        android:layout_gravity="end"
        android:layout_alignParentTop="true"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:id="@+id/tv_message"
        android:text="Confirm"
        android:textColor="@color/black"
        android:fontFamily="@font/montserrat_semi_bold"
        android:textSize="@dimen/text_size_18sp"
        android:layout_below="@+id/cancel"

        />


    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:id="@+id/tv1"
        android:text="Confirm"
        android:textColor="@color/teal"
        android:fontFamily="@font/montserrat_semi_bold"
        android:textSize="@dimen/text_size_18sp"
        android:layout_below="@+id/cancel"
        android:layout_marginTop="@dimen/space_2dp"
        android:visibility="gone"
        />


    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:id="@+id/tv2"
        android:text="Confirm"
        android:textColor="@color/black"
        android:fontFamily="@font/montserrat_semi_bold"
        android:textSize="@dimen/text_size_18sp"
        android:layout_below="@+id/cancel"
        android:visibility="gone"
        android:layout_marginTop="@dimen/space_2dp"
        />



    <Button
        android:id="@+id/confirm"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/space_30dp"
        android:gravity="center"
android:layout_gravity="center_horizontal"
        android:background="@drawable/teal_bg_round_corner"
        android:layout_marginEnd="@dimen/space_16dp"
        style="@style/SemiBold.White.TextSize12"
        android:text="Confirm"
        android:layout_marginBottom="@dimen/space_20dp"

        android:layout_below="@+id/tv_message"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="@dimen/space_20dp"
        />

</LinearLayout>