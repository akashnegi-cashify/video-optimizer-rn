<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/space_10dp"
    android:elevation="@dimen/cardview_default_elevation">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/space_5dp"
        android:orientation="vertical">


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"

            android:orientation="horizontal">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:id="@+id/tv_part_name"
                style="@style/Medium.Teal.TextSize14"
                android:text="@string/part_name"/>



            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                style="@style/Medium.JetBlack.TextSize14"
                android:layout_marginStart="@dimen/space_10dp"

                android:id="@+id/name"
                tools:text="jhdfkdklsdzfd"/>



        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_10dp"

            android:orientation="horizontal">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:id="@+id/tv_part_status"
                style="@style/Medium.Teal.TextSize14"

                android:text="@string/status"/>



            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                style="@style/Medium.JetBlack.TextSize14"
                android:layout_marginStart="@dimen/space_10dp"

                android:id="@+id/tv_status"
                tools:text="jhdfkdklsdzfd"/>



        </LinearLayout>


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_10dp"

            android:orientation="horizontal">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:id="@+id/tv_part_sku"

                style="@style/Medium.Teal.TextSize14"
                android:text="@string/skuu"/>



            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                style="@style/Medium.JetBlack.TextSize14"
                android:layout_marginStart="@dimen/space_10dp"

                android:id="@+id/tv_folder"
                tools:text="jhdfkdklsdzfd"/>



        </LinearLayout>


        <LinearLayout
            android:layout_marginBottom="@dimen/space_10dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_10dp"

            android:orientation="horizontal">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:id="@+id/lbl_requested_at"

                style="@style/Medium.Teal.TextSize14"
                android:text="@string/requested_at"/>



            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                style="@style/Medium.JetBlack.TextSize14"
                android:layout_marginStart="@dimen/space_10dp"

                android:id="@+id/tv_requested_at"
                tools:text="jhdfkdklsdzfd"/>



        </LinearLayout>



    </LinearLayout>



</androidx.cardview.widget.CardView>