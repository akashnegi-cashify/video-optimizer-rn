<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="@dimen/space_10dp"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <TextView
        android:textAllCaps="true"
        android:layout_marginTop="@dimen/space_20dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/tv"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:gravity="center"
        style="@style/Medium.JetBlack.TextSize16"
        android:text="@string/msg_rec_part"/>

    <TextView

        android:textStyle="bold"
        android:textColor="@color/confirm"
        android:textSize="@dimen/space_20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginVertical="@dimen/space_18dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/tv_barcode_rec"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv"
        app:layout_constraintEnd_toEndOf="parent"
        android:gravity="center" />
</androidx.constraintlayout.widget.ConstraintLayout>