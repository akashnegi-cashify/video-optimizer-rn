<?xml version="1.0" encoding="utf-8"?>

<androidx.cardview.widget.CardView xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:id="@+id/card"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_margin="@dimen/space_10dp"
    android:elevation="@dimen/cardview_default_elevation"><LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
<androidx.constraintlayout.widget.ConstraintLayout android:layout_width="match_parent"
    android:layout_height="wrap_content"
   android:layout_margin="@dimen/space_3dp"
    android:background="@color/white"
    android:padding="@dimen/space_3dp"
    android:orientation="horizontal">


    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:id="@+id/tv_count"
        android:layout_marginStart="@dimen/space_2dp"
        tools:text="1"

        app:layout_constraintTop_toTopOf="parent"
        style="@style/Medium.Teal.TextSize14"
        app:layout_constraintStart_toStartOf="parent"/>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/space_5dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toEndOf="@+id/tv_count"
        android:layout_marginStart="@dimen/space_20dp"
        android:id="@+id/lay_device_barcode"
        android:orientation="horizontal">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            style="@style/Medium.Teal.TextSize14"
            android:text="@string/device_barcode"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            style="@style/Medium.JetBlack.TextSize14"
            android:id="@+id/tv_barcode"
            android:layout_marginStart="@dimen/space_10dp"
            tools:text="dfuyfjdifflyudfukl"/>


    </LinearLayout>



    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/space_5dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@+id/lay_device_barcode"
        app:layout_constraintStart_toEndOf="@+id/tv_count"
        android:layout_marginStart="@dimen/space_20dp"
        android:id="@+id/lay_engineer_name">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            style="@style/Medium.Teal.TextSize14"
            android:text="@string/engineers_name"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            style="@style/Medium.JetBlack.TextSize14"
            android:id="@+id/tv_engineer_name"
            android:layout_marginStart="@dimen/space_10dp"
            tools:text="dfuyfjdifflyudfukl"/>


    </LinearLayout>




    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/space_5dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@+id/lay_engineer_name"
        app:layout_constraintStart_toEndOf="@+id/tv_count"
        android:layout_marginStart="@dimen/space_20dp"
        android:id="@+id/lay_device_location">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            style="@style/Medium.Teal.TextSize14"
            android:text="@string/location"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            style="@style/Medium.JetBlack.TextSize14"
            android:id="@+id/tv_location"
            android:layout_marginStart="@dimen/space_10dp"
            tools:text="dfuyfjdifflyudfukl"/>


    </LinearLayout>



    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/space_5dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@+id/lay_device_location"
        app:layout_constraintStart_toEndOf="@+id/tv_count"
        android:layout_marginStart="@dimen/space_20dp"
        android:id="@+id/lay_part_status">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            style="@style/Medium.Teal.TextSize14"
            android:text="@string/part_status"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            style="@style/Medium.JetBlack.TextSize14"
            android:id="@+id/tv_part_status"
            android:layout_marginStart="@dimen/space_10dp"
            tools:text="dfuyfjdifflyudfukl"/>


    </LinearLayout>




    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/space_5dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@+id/lay_part_status"
        app:layout_constraintStart_toEndOf="@+id/tv_count"
        android:layout_marginStart="@dimen/space_20dp"
        android:id="@+id/lay_assigned_at">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            style="@style/Medium.Teal.TextSize14"
            android:text="@string/assigned_at"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            style="@style/Medium.JetBlack.TextSize14"
            android:id="@+id/tv_assignes_at"
            android:layout_marginStart="@dimen/space_10dp"
            tools:text="17-May-2020 7:30 pm"/>


    </LinearLayout>


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/space_5dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@+id/lay_assigned_at"
        app:layout_constraintStart_toEndOf="@+id/tv_count"
        android:layout_marginStart="@dimen/space_20dp"
        android:id="@+id/lay_repair_type">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            style="@style/Medium.Teal.TextSize14"
            android:text="@string/repair_type"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            style="@style/Medium.JetBlack.TextSize14"
            android:id="@+id/tv_repair_type"
            android:layout_marginStart="@dimen/space_10dp"
            tools:text=""/>


    </LinearLayout>


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/space_5dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@+id/lay_repair_type"
        app:layout_constraintStart_toEndOf="@+id/tv_count"
        android:layout_marginStart="@dimen/space_20dp"
        android:id="@+id/lay_grade">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            style="@style/Medium.Teal.TextSize14"
            android:text="@string/grade"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            style="@style/Medium.JetBlack.TextSize14"
            android:id="@+id/tv_grade"
            android:layout_marginStart="@dimen/space_10dp"
            tools:text=""/>


    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>

</LinearLayout>
</androidx.cardview.widget.CardView>