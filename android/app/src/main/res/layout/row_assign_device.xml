<?xml version="1.0" encoding="utf-8"?>

<androidx.cardview.widget.CardView xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/space_10dp"
    app:cardBackgroundColor="@color/red"
android:id="@+id/card"
    android:elevation="@dimen/cardview_default_elevation">


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/space_3dp"
        android:padding="@dimen/space_2dp"
        android:background="@color/white"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="@dimen/space_30dp"
            android:layout_height="@dimen/space_30dp"
            android:background="@drawable/ic_teal_square"
android:src="@drawable/ic_done"
            android:padding="@dimen/space_7dp"
            android:id="@+id/img"/>
    <LinearLayout  android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/space_10dp"
        android:orientation="vertical">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="@dimen/space_5dp"
            android:orientation="horizontal">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                style="@style/Medium.Teal.TextSize14"
                android:text="@string/device_barcode"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                style="@style/Medium.JetBlack.TextSize14"
                android:id="@+id/tv_barcode"
                android:layout_marginStart="@dimen/space_10dp"
                tools:text="dfuyfjdifflyudfukl"/>


        </LinearLayout>



        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="@dimen/space_5dp"
            android:orientation="horizontal">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                style="@style/Medium.Teal.TextSize14"
                android:text="@string/engineers_name"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                style="@style/Medium.JetBlack.TextSize14"
                android:id="@+id/tv_engineer_name"
                android:layout_marginStart="@dimen/space_10dp"
                tools:text="dfuyfjdifflyudfukl"/>


        </LinearLayout>




        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="@dimen/space_5dp"
            android:orientation="horizontal">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                style="@style/Medium.Teal.TextSize14"
                android:text="@string/location"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                style="@style/Medium.JetBlack.TextSize14"
                android:id="@+id/tv_location"
                android:layout_marginStart="@dimen/space_10dp"
                tools:text="dfuyfjdifflyudfukl"/>


        </LinearLayout>



        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="@dimen/space_5dp"
            android:orientation="horizontal">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                style="@style/Medium.Teal.TextSize14"
                android:text="@string/part_assigned"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                style="@style/Medium.JetBlack.TextSize14"
                android:id="@+id/tv_part_status"
                android:layout_marginStart="@dimen/space_10dp"
                tools:text="dfuyfjdifflyudfukl"/>


        </LinearLayout>



        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="@dimen/space_5dp"
            android:orientation="horizontal"
            android:id="@+id/lay_assigned_at">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                style="@style/Medium.Teal.TextSize14"
                android:text="@string/assigned_at"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                style="@style/Medium.JetBlack.TextSize14"
                android:id="@+id/tv_assignes_at"
                android:layout_marginStart="@dimen/space_10dp"
                tools:text="17-May-2020 7:30 pm"/>


        </LinearLayout>


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="@dimen/space_5dp"
            android:orientation="horizontal"
            android:id="@+id/lay_rt">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                style="@style/Medium.Teal.TextSize14"
                android:text="@string/repair_type"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                style="@style/Medium.JetBlack.TextSize14"
                android:id="@+id/tv_repair_type"
                android:layout_marginStart="@dimen/space_10dp"
                tools:text=""/>


        </LinearLayout>


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="@dimen/space_5dp"
            android:orientation="horizontal"
            android:id="@+id/lay_grade">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                style="@style/Medium.Teal.TextSize14"
                android:text="@string/grade"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                style="@style/Medium.JetBlack.TextSize14"
                android:id="@+id/tv_grade"
                android:layout_marginStart="@dimen/space_10dp"
                tools:text=""/>


        </LinearLayout>

    </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>