<?xml version="1.0" encoding="utf-8"?>

<layout
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    >
    <androidx.cardview.widget.CardView
         android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/space_10dp"
        android:elevation="@dimen/cardview_default_elevation">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="@dimen/space_5dp"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    style="@style/Medium.Teal.TextSize14"
                    android:text="@string/device_barcode"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    style="@style/Medium.JetBlack.TextSize14"
                    android:id="@+id/tv_device_barcode"
                    android:layout_marginStart="@dimen/space_10dp"
                    tools:text=""/>


            </LinearLayout>


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="@dimen/space_5dp"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    style="@style/Medium.Teal.TextSize14"
                    android:text="@string/device_name"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    style="@style/Medium.JetBlack.TextSize14"
                    android:id="@+id/tv_device_name"
                    android:layout_marginStart="@dimen/space_10dp"
                    tools:text=""/>


            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="@dimen/space_5dp"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    style="@style/Medium.Teal.TextSize14"
                    android:text="@string/device_id"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    style="@style/Medium.JetBlack.TextSize14"
                    android:id="@+id/tv_device_id"
                    android:layout_marginStart="@dimen/space_10dp"
                    tools:text=""/>


            </LinearLayout>

            <LinearLayout
                android:paddingTop="@dimen/common_uploader_space_10dp"
                android:paddingBottom="@dimen/common_uploader_space_15dp"
                android:gravity="center"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <Button
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/TealButtonRoundCorner"
                    android:layout_marginStart="@dimen/space_10dp"
                    android:text="@string/rubbing_not_done"
                    android:minHeight="0dp"
                    android:paddingEnd="@dimen/space_8dp"
                    android:paddingStart="@dimen/space_8dp"
                    android:paddingTop="@dimen/space_5dp"
                    android:paddingBottom="@dimen/space_5dp"
                    android:id="@+id/btn_rubbing_not_done"/>

                <Button
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/TealButtonRoundCorner"
                    android:layout_marginStart="@dimen/space_10dp"
                    android:text="@string/rubbing_done"
                    android:minHeight="0dp"
                    android:paddingEnd="@dimen/space_8dp"
                    android:paddingStart="@dimen/space_8dp"
                    android:paddingTop="@dimen/space_5dp"
                    android:paddingBottom="@dimen/space_5dp"
                    android:id="@+id/btn_rubbing_done"/>

            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>
</layout>
