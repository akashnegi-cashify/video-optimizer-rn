<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:padding="@dimen/space_10dp"
        android:orientation="vertical"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:id="@+id/lay_name"

            android:orientation="horizontal">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                style="@style/Medium.Teal.TextSize16"
                android:text="@string/part_name"
                android:layout_weight="1"/>
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:layout_marginStart="@dimen/space_10dp"
                style="@style/Medium.JetBlack.TextSize16"
                android:id="@+id/tv_part_name"
                android:layout_weight="1"/>
        </LinearLayout>


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_5dp"
            android:orientation="horizontal"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/lay_name"
            android:id="@+id/lay_sku">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                style="@style/Medium.Teal.TextSize16"
                android:text="@string/part_sku"
                android:layout_weight="1"/>
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                style="@style/Medium.JetBlack.TextSize16"
                android:layout_marginStart="@dimen/space_10dp"
                android:id="@+id/tv_part_sku"
                android:layout_weight="1"/>
        </LinearLayout>




        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_5dp"
            android:orientation="horizontal"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/lay_sku"
            android:id="@+id/lay_color">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                style="@style/Medium.Teal.TextSize16"
                android:text="@string/part_color"
                android:layout_weight="1"/>
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:layout_marginStart="@dimen/space_10dp"
                style="@style/Medium.JetBlack.TextSize16"
                android:id="@+id/tv_part_color"
                android:layout_weight="1"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_5dp"
            android:orientation="horizontal"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/lay_color"
            android:id="@+id/lay_barcode">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                style="@style/Medium.Teal.TextSize16"
                android:text="@string/part_barcode"
                android:layout_weight="1"/>
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                style="@style/Medium.JetBlack.TextSize16"
                android:layout_marginStart="@dimen/space_10dp"
                android:id="@+id/tv_part_barcode"
                android:layout_weight="1"/>
        </LinearLayout>


        <Button
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:id="@+id/faulty_spare"
            android:text="@string/faulty_spare"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:background="@color/red"
            android:textColor="@color/white"
            android:layout_margin="@dimen/space_10dp"
            app:layout_constraintEnd_toStartOf="@+id/spare_ok"/>


        <Button
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:id="@+id/spare_ok"
            android:text="@string/spare_ok"
            app:layout_constraintStart_toEndOf="@+id/faulty_spare"
            app:layout_constraintBottom_toBottomOf="parent"
            android:background="@color/teal"
            android:textColor="@color/white"
            android:layout_margin="@dimen/space_10dp"
            app:layout_constraintEnd_toEndOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>