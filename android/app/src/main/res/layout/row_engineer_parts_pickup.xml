<?xml version="1.0" encoding="utf-8"?>

<androidx.cardview.widget.CardView
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/space_10dp"

    android:elevation="@dimen/cardview_default_elevation">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/space_10dp"
        android:orientation="horizontal">



        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/tv_no"
            tools:text="1"
            android:padding="@dimen/space_5dp"

            style="@style/Medium.JetBlack.TextSize16"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:padding="@dimen/space_5dp"
                android:layout_weight="1"
                android:orientation="vertical">


                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    style="@style/Medium.JetBlack.TextSize14"
                    android:id="@+id/tv_part_name"
                    android:layout_marginStart="@dimen/space_10dp"
                    tools:text="dfuyfjdifflyudfukl"/>




                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    style="@style/Medium.Teal.TextSize14"
                    android:id="@+id/tv_part_barcode"
                    android:layout_marginTop="@dimen/space_3dp"
                    android:layout_marginBottom="@dimen/space_3dp"
                    android:layout_marginStart="@dimen/space_10dp"
                    tools:text="dfuyfjdifflyudfukl"/>









                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    style="@style/Medium.JetBlack.TextSize14"
                    android:id="@+id/tv_part_sku"
                    android:layout_marginStart="@dimen/space_10dp"
                    tools:text="dfuyfjdifflyudfukl"/>












        </LinearLayout>




        <Button
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/TealButtonRoundCorner"
            android:layout_marginStart="@dimen/space_10dp"
            android:text="@string/receive"
            android:minHeight="0dp"
            android:paddingTop="@dimen/space_5dp"
            android:paddingBottom="@dimen/space_5dp"
            android:id="@+id/receive"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>