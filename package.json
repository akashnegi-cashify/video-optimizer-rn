{
  "name": "@cashify/video-optimizer-rn",
  "version": "0.1.0",
  "description": "React Native port of the Flutter video_optimizer package. FFmpeg-based video and image optimization with progress callbacks.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts,.tsx",
    "prepublishOnly": "npm run clean && npm run build && npm test"
  },
  "keywords": [
    "react-native",
    "ffmpeg",
    "video",
    "compression",
    "optimization",
    "image"
  ],
  "author": "Cashify",
  "license": "GPL-3.0-or-later",
  "peerDependencies": {
    "ffmpeg-kit-react-native": ">=6.0.0",
    "react": ">=17.0.0",
    "react-native": ">=0.71.0"
  },
  "dependencies": {
    "react-native-fs": "^2.20.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/react": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "ffmpeg-kit-react-native": "^6.0.2",
    "jest": "^29.0.0",
    "prettier": "^3.0.0",
    "react": "19",
    "react-native": "0.85",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "<rootDir>/__tests__/**/*.test.ts"
    ],
    "moduleNameMapper": {
      "^ffmpeg-kit-react-native$": "<rootDir>/__mocks__/ffmpeg-kit-react-native.ts",
      "^react-native-fs$": "<rootDir>/__mocks__/react-native-fs.ts"
    }
  }
}
